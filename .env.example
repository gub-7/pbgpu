# GPU Cluster Configuration

# API Server
HOST=0.0.0.0
PORT=8000
ENV=production

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage Configuration
STORAGE_ROOT=storage

# Worker Configuration
TRIPOSR_POLL_INTERVAL=2.0
TRELLIS2_POLL_INTERVAL=2.0

# CUDA Configuration
CUDA_HOME=/usr/local/cuda-12.8
CUDA_VISIBLE_DEVICES=0

# Model Cache Directories
HF_HOME=/home/user/.cache/huggingface
TORCH_HOME=/home/user/.cache/torch

# Hugging Face Token (required for gated models like DINOv3)
# Get your token at https://huggingface.co/settings/tokens
# Required for TRELLIS.2 pipeline (uses facebook/dinov3-vitl16-pretrain-lvd1689m)
HF_TOKEN=

# TRELLIS.2 Configuration
# Path to TRELLIS.2 repo (if installed locally, not via pip)
TRELLIS2_REPO=/opt/trellis2
PYTHONPATH=/opt/trellis2

# Preprocessing Configuration
DEFAULT_FOREGROUND_RATIO=0.85
DEFAULT_TEXTURE_RESOLUTION=2048

# Logging
LOG_LEVEL=INFO
