# GPU Cluster Multi-View Reconstruction – Environment Configuration
# Copy to .env and customize for your deployment

# ---------------------------------------------------------------
# Redis
# ---------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------
# Storage
# ---------------------------------------------------------------
STORAGE_ROOT=./storage
LOG_DIR=./logs
MODEL_CACHE_DIR=./model_cache

# ---------------------------------------------------------------
# CUDA / GPU
# ---------------------------------------------------------------
CUDA_DEVICE=cuda
CUDA_HOME=/usr/local/cuda

# ---------------------------------------------------------------
# Reconstruction backend
# ---------------------------------------------------------------
# Options: dust3r, mast3r, vggt
DEFAULT_RECON_BACKEND=dust3r

# DUSt3R / MASt3R model checkpoints
DUST3R_CHECKPOINT=./model_cache/DUSt3R_ViTLarge_BaseDecoder_512_dpt.pth
MAST3R_CHECKPOINT=./model_cache/MASt3R_ViTLarge_BaseDecoder_512_catmlpdpt_metric.pth

# ---------------------------------------------------------------
# Pipeline settings
# ---------------------------------------------------------------
USE_BACKGROUND_FOR_POSE=true
TRELLIS_ENABLED=true
DEFAULT_MASK_METHOD=rembg
DEFAULT_IMAGE_SIZE=2048

# ---------------------------------------------------------------
# Camera defaults
# ---------------------------------------------------------------
DEFAULT_CAMERA_RADIUS=1.2
DEFAULT_FOCAL_LENGTH=1700.0

# ---------------------------------------------------------------
# External model paths
# ---------------------------------------------------------------
TRELLIS_REPO_DIR=/root/TRELLIS.2
TRIPOSR_REPO_DIR=/root/TripoSR

# ---------------------------------------------------------------
# Worker settings
# ---------------------------------------------------------------
WORKER_TIMEOUT=1800
POLL_INTERVAL=5

# ---------------------------------------------------------------
# Hugging Face (for gated models)
# ---------------------------------------------------------------
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
